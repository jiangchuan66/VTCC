.match-card {
  padding: 24rpx;
  overflow: hidden;
  border: 2rpx solid #e5e6eb;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(29, 33, 41, 0.035);
  transition: transform 150ms, border-color 150ms;
}

.match-card--pressed {
  transform: scale(0.99);
}

.match-card__meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: #4e5969;
  font-size: 22rpx;
}

.match-card__league {
  min-width: 0;
  margin-right: auto;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.match-card__status {
  padding: 6rpx 14rpx;
  border-radius: 12rpx;
  background: #f7f8fa;
  color: #4e5969;
  white-space: nowrap;
}

.match-card__status--live {
  background: #fff0f1;
  color: #ff4655;
  font-weight: 600;
}

.match-card__teams {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 108rpx minmax(0, 1fr);
  align-items: center;
  margin-top: 24rpx;
}

.team {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.team--away {
  flex-direction: row-reverse;
  text-align: right;
}

.team__logo {
  width: 72rpx;
  height: 72rpx;
  flex: 0 0 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: #1d2129;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 800;
}

.team__logo--gold {
  background: #8f555c;
}

.team__logo--orange {
  background: #ef6741;
}

.team__logo--red {
  background: #d83d49;
}

.team__logo--blue {
  background: #315c72;
}

.team__name {
  min-width: 0;
  overflow: hidden;
  color: #1d2129;
  font-size: 28rpx;
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.score {
  min-width: 128rpx;
  display: grid;
  grid-template-columns: 1fr 24rpx 1fr;
  align-items: center;
  color: #1d2129;
  font-family: "SFMono-Regular", Consolas, monospace;
  font-size: 40rpx;
  font-weight: 700;
  font-variant-numeric: tabular-nums;
  line-height: 1;
  text-align: center;
  white-space: nowrap;
}

.score--versus {
  display: block;
  color: #4e5969;
  font-size: 24rpx;
  font-weight: 400;
}

.score__number--leading {
  color: #ff4655;
}

.section-header {
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-header__title {
  color: #1d2129;
  font-size: 36rpx;
  font-weight: 700;
}

.section-header__action {
  min-width: 88rpx;
  height: 88rpx;
  margin: 0;
  padding: 0 0 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  border: 0;
  border-radius: 0;
  background: transparent;
  color: #86909c;
  font-size: 24rpx;
  line-height: 1;
}

.section-header__action::after {
  border: 0;
}

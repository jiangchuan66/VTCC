.state-box {
  min-height: 472rpx;
  margin-top: 20rpx;
  padding: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e5e6eb;
  border-radius: 24rpx;
  background: #ffffff;
  box-sizing: border-box;
  text-align: center;
}

.state-box__icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f7f8fa;
  color: #86909c;
  font-size: 40rpx;
}

.state-box__title {
  color: #1d2129;
  font-size: 30rpx;
  font-weight: 700;
}

.state-box__description {
  margin-top: 14rpx;
  color: #86909c;
  font-size: 24rpx;
  line-height: 1.5;
}

.state-box__action {
  height: 80rpx;
  margin-top: 30rpx;
  padding: 0 44rpx;
  border: 2rpx solid #e5e6eb;
  border-radius: 18rpx;
  background: #ffffff;
  color: #1d2129;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 78rpx;
}

.state-box__action::after {
  border: 0;
}

.skeleton {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.skeleton__block {
  height: 28rpx;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #e5e6eb 25%, #ffffff 45%, #e5e6eb 65%);
  background-size: 220% 100%;
  animation: skeleton-loading 1.35s infinite;
}

.skeleton__block--short {
  width: 42%;
}

.skeleton__block--card {
  height: 140rpx;
}

@keyframes skeleton-loading {
  to {
    background-position: -220% 0;
  }
}
